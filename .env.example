# ──────────────────────────────────────────────────────────
# .env.example — Gapai Frontend
# Copy this file to .env.local and fill in real values.
# Never commit .env.local to git.
# ──────────────────────────────────────────────────────────

# Base URL for all API requests (no trailing slash)
NEXT_PUBLIC_API_URL=https://api.gapai.id/v1

# Set to "true" to intercept all API calls with MSW mock handlers.
# Run `npx msw init public/ --save` once after cloning to set up the service worker.
NEXT_PUBLIC_ENABLE_MOCK=true
